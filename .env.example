# 실제 값은 .env에만 저장 (git 커밋 금지 — .gitignore 참조)

# OpenAI (에이전트 gpt-4o-mini / 임베딩 text-embedding-3-small / eval judge gpt-4o)
OPENAI_API_KEY=sk-...

# Slack 봇 (Bot Token Scopes: app_mentions:read, chat:write)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# 주간 리포트를 포스팅할 채널 ID
SLACK_REPORT_CHANNEL=C...

# PostgreSQL (docker-compose.yml 기본값 기준)
DATABASE_URL=postgresql://voc:voc@localhost:5432/voc

# 소스 리뷰 데이터 (SQLite, 리포 외부 경로)
SOURCE_DB_PATH=C:/path/to/ms_reviews.db

# (선택) LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=voc-agent
